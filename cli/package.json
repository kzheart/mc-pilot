{
  "name": "@kzheart_/mc-pilot",
  "version": "0.9.5",
  "description": "Minecraft plugin/mod automated testing CLI – control a real Minecraft client to simulate player actions",
  "type": "module",
  "bin": {
    "mct": "bin/mct"
  },
  "files": [
    "bin/",
    "dist/",
    "data/",
    "scripts/",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.e2e.test.js",
    "!dist/**/*.e2e.test.d.ts"
  ],
  "keywords": [
    "minecraft",
    "testing",
    "automation",
    "fabric",
    "plugin",
    "mod",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kzheart/mc-pilot.git",
    "directory": "cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test dist/*.test.js dist/**/*.test.js",
    "test:e2e": "tsc -p tsconfig.json && node --test dist/*.e2e.test.js"
  },
  "dependencies": {
    "@xmcl/core": "^2.15.1",
    "@xmcl/file-transfer": "^2.0.3",
    "@xmcl/installer": "^6.1.2",
    "commander": "^14.0.1",
    "pngjs": "^7.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
